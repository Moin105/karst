KARST_SESSION_SECRET=change_me_32_chars_minimum
KARST_ADMIN_EMAIL=you@example.com
KARST_ADMIN_PASSWORD_HASH=scrypt:N=16384:<salt_hex>:<hash_hex>
KARST_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://karst.dev

# Database — PostgreSQL (Neon). Local dev can point at a local Postgres
# (no SSL); production uses the Neon pooled connection string (SSL is enabled
# automatically for any non-local host).
#   Local:      postgres://user:pass@localhost:5432/karst
#   Neon:       postgres://<user>:<pass>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# Email — Resend (https://resend.com). Leave RESEND_API_KEY empty to disable
# email entirely (signups still work). EMAIL_FROM must use a domain you've
# verified in Resend before you can email arbitrary signups.
RESEND_API_KEY=
EMAIL_FROM=karst <onboarding@resend.dev>
# EMAIL_REPLY_TO=hello@karst.dev
# OWNER_NOTIFY_EMAIL=you@example.com
