KARST_SESSION_SECRET=change_me_32_chars_minimum
KARST_ADMIN_EMAIL=you@example.com
# Generate with: npm run hash-password
KARST_ADMIN_PASSWORD_HASH=scrypt:N=16384:<salt_hex>:<hash_hex>
KARST_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://karst.dev

# Database — PostgreSQL (Neon). SSL is enabled automatically for non-local hosts.
#   Local:  postgres://user:pass@localhost:5432/karst
#   Neon:   postgres://<user>:<pass>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# Email — SMTP via Nodemailer (e.g. Gmail). Leave SMTP_* empty to disable email
# (signups still work). Gmail requires an App Password (2FA must be on).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=
EMAIL_FROM=karst <you@gmail.com>
# EMAIL_REPLY_TO=you@gmail.com
# OWNER_NOTIFY_EMAIL=you@gmail.com
