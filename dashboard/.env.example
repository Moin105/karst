KARST_SESSION_SECRET=change_me_32_chars_minimum
KARST_ADMIN_EMAIL=you@example.com
# Generate with: npm run hash-password
KARST_ADMIN_PASSWORD_HASH=scrypt:N=16384:<salt_hex>:<hash_hex>
# CORS allowlist for the public landing forms (waitlist + feedback). MUST include
# the EXACT origin the landing site is served from, or the forms silently fail in
# the browser. Add your live landing URL here (custom domain AND/OR the raw
# *.vercel.app preview URL while DNS isn't wired yet). Comma-separated, no wildcard.
KARST_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://karst.dev,https://www.karst.dev

# Public origin of THIS dashboard, used to build password-reset links safely
# (prevents Host-header poisoning). On Vercel this is optional (VERCEL_URL is
# auto-injected); set it to your custom domain if you have one. REQUIRED in
# production on non-Vercel hosts (Fly, self-hosted), or reset emails won't send.
KARST_PUBLIC_URL=https://your-dashboard.example.com

# Database — PostgreSQL (Neon). SSL is enabled automatically for non-local hosts.
#   Local:  postgres://user:pass@localhost:5432/karst
#   Neon:   postgres://<user>:<pass>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# Social pipeline (n8n). See marketing/n8n/README.md.
#  - KARST_SOCIAL_INGEST_TOKEN: shared secret n8n uses to push drafts / status to
#    the dashboard. Until set, the social ingest endpoints are DISABLED (503).
#    Generate one: `openssl rand -hex 24`. Use the SAME value in n8n's Header Auth.
#  - KARST_N8N_BASE_URL: where the dashboard reaches n8n (server-side). localhost
#    is right when the dashboard runs on the same machine as n8n; for a hosted
#    dashboard point it at a tunnel/public n8n URL.
KARST_SOCIAL_INGEST_TOKEN=
KARST_N8N_BASE_URL=http://localhost:5678
# KARST_N8N_GENERATE_PATH=/webhook/karst-social-generate
# KARST_N8N_PUBLISH_PATH=/webhook/karst-social-publish

# Email — SMTP via Nodemailer (e.g. Gmail). Leave SMTP_* empty to disable email
# (signups still work). Gmail requires an App Password (2FA must be on).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=
EMAIL_FROM=karst <you@gmail.com>
# EMAIL_REPLY_TO=you@gmail.com
# OWNER_NOTIFY_EMAIL=you@gmail.com
