KARST_SESSION_SECRET=change_me_32_chars_minimum
KARST_ADMIN_EMAIL=you@example.com
KARST_ADMIN_PASSWORD_HASH=scrypt:N=16384:<salt_hex>:<hash_hex>
KARST_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://karst.dev

# Database — Turso (libsql). Leave the URL unset for local dev and it uses a
# local file (file:./karst.db). For production set both:
#   TURSO_DATABASE_URL=libsql://<your-db>.turso.io
#   TURSO_AUTH_TOKEN=<token from `turso db tokens create <db>`>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
